# ════════════════════════════════════════════════════════
# ServicerRisk — Production Environment Variables
# Product: servicerrisk  |  Subdomain: servicerrisk.data.huit.ai
# ════════════════════════════════════════════════════════
# DO NOT COMMIT ACTUAL VALUES — use Vercel dashboard

# ── Supabase (pre-configured) ─────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://vvkdnzqgtajeouxlliuk.supabase.co
SUPABASE_SERVICE_ROLE_KEY=REPLACE_WITH_SERVICE_ROLE_KEY

# ── Product Identity (pre-configured) ────────────────
NEXT_PUBLIC_PRODUCT_SLUG=servicerrisk
NEXT_PUBLIC_PRODUCT_NAME=ServicerRisk
NEXT_PUBLIC_SUBDOMAIN=servicerrisk.data.huit.ai
NEXT_PUBLIC_PRICE_CENTS=450000

# ── Stripe (set after running huit_stripe_setup.py) ──
STRIPE_SECRET_KEY=sk_live_REPLACE_AFTER_RUNNING_STRIPE_SCRIPT
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_REPLACE_AFTER_RUNNING_STRIPE_SCRIPT
STRIPE_PRICE_ID=price_REPLACE_AFTER_RUNNING_STRIPE_SCRIPT
STRIPE_PRICE_ID_ANNUAL=price_REPLACE_AFTER_RUNNING_STRIPE_SCRIPT
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_AFTER_REGISTERING_WEBHOOK

# ── Auth ──────────────────────────────────────────────
JWT_SECRET=REPLACE_WITH_32_CHAR_RANDOM_STRING

# ── Email (Resend) ────────────────────────────────────
RESEND_API_KEY=re_REPLACE_WITH_RESEND_KEY
FROM_EMAIL=noreply@servicerrisk.data.huit.ai

# ── Vercel (auto-set by Vercel, do not touch) ─────────
# VERCEL_URL is auto-injected by Vercel

# ════════════════════════════════════════════════════════
# SETUP CHECKLIST (complete in order):
# 1. Run scripts/huit_stripe_setup.py to get price IDs
# 2. Set STRIPE_PRICE_ID from stripe_manifest.json output
# 3. Register Stripe webhook at dashboard.stripe.com/webhooks
#    Endpoint: https://servicerrisk.data.huit.ai/api/stripe/webhook
#    Events: customer.subscription.created, 
#            customer.subscription.updated,
#            customer.subscription.deleted,
#            checkout.session.completed
# 4. Set STRIPE_WEBHOOK_SECRET from webhook signing secret
# 5. Add *.data.huit.ai CNAME → cname.vercel-dns.com in DNS
# 6. In Vercel project: Domains → Add servicerrisk.data.huit.ai
# ════════════════════════════════════════════════════════
